## Source the CC0 species icons + convert
$ B=https://raw.githubusercontent.com/openfarmcc/open-crop-icons/mainline/icons
$ for c in tomato basil strawberry tomatillo generic-plant; do curl -fsSL "$B/$c/$c.svg" -o /tmp/crop-$c.svg; done   -> all OK
# upstream SVGs use CSS <style> classes + <circle> → not Android-vector compatible.
$ npx svgo --config (inlineStyles + convertStyleToAttrs + removeStyleElement + convertShapeToPath) -> /tmp/inlined-*.svg  (8/22/37/6/9 fill attrs)
$ npx svg2vectordrawable -i inlined-*.svg -o ic_species_*.xml   -> vector drawables WITH fillColor
# passionfruit <- generic-plant copy. Installed all 6 into res/drawable; deleted old placeholder species (overwritten).

## Pots + locations -> Material Symbols
# libs.versions.toml: +compose-material-icons-extended (BOM-managed)
# feature-inventory/build.gradle.kts: +implementation(libs.compose.material.icons.extended)
# WizardIcons.kt: potIcon(label) -> LocalFlorist (small) / Compost (bucket) / Window (window box) / Grass (raised bed);
#                 locationIcon(kind) -> WbSunny / Balcony / Cottage / Home
# AddPlantWizard.kt: Tile leadingIcon slot; species Image(painterResource), pots/locations Icon(imageVector)
# deleted ic_loc_*.xml + ic_pot.xml ; added feature-inventory/ICON_LICENSES.md (NOT in res/drawable -> aapt)

